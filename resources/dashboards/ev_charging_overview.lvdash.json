{
  "datasets": [
    {
      "name": "f9ddad46",
      "displayName": "Tile 1: Top stations by total kWh",
      "queryLines": [
        "SELECT\r\n",
        "  station_name,\r\n",
        "  SUM(total_energy_kwh) AS total_energy_kwh,\r\n",
        "  SUM(sessions_count) AS sessions_count\r\n",
        "FROM ev_charging_demo.gold.station_daily_kpis\r\n",
        "GROUP BY station_name\r\n",
        "ORDER BY total_energy_kwh DESC\r\n",
        "LIMIT 10;"
      ]
    },
    {
      "name": "5cc675f2",
      "displayName": "Tile 2: Sessions and kWh by hour of day",
      "queryLines": [
        "SELECT\r\n",
        "  session_hour,\r\n",
        "  SUM(sessions_count) AS sessions_count,\r\n",
        "  SUM(total_energy_kwh) AS total_energy_kwh\r\n",
        "FROM ev_charging_demo.gold.station_hourly_demand\r\n",
        "GROUP BY session_hour\r\n",
        "ORDER BY session_hour;"
      ]
    },
    {
      "name": "a1d02477",
      "displayName": "Tile 3: Weekday vs weekend demand",
      "queryLines": [
        "SELECT\r\n",
        "  CASE WHEN is_weekend THEN 'Weekend' ELSE 'Weekday' END AS day_type,\r\n",
        "  SUM(sessions_count) AS sessions_count,\r\n",
        "  SUM(total_energy_kwh) AS total_energy_kwh\r\n",
        "FROM ev_charging_demo.gold.station_daily_kpis\r\n",
        "GROUP BY CASE WHEN is_weekend THEN 'Weekend' ELSE 'Weekday' END\r\n",
        "ORDER BY day_type;"
      ]
    },
    {
      "name": "39ee3f9b",
      "displayName": "Tile 4: Average duration by station",
      "queryLines": [
        "SELECT\r\n",
        "  station_name,\r\n",
        "  SUM(sessions_count * avg_duration_minutes) / NULLIF(SUM(sessions_count), 0)\r\n",
        "    AS avg_duration_minutes,\r\n",
        "  SUM(sessions_count) AS sessions_count\r\n",
        "FROM ev_charging_demo.gold.station_daily_kpis\r\n",
        "GROUP BY station_name\r\n",
        "ORDER BY avg_duration_minutes DESC\r\n",
        "LIMIT 15;"
      ]
    },
    {
      "name": "b2a5da4a",
      "displayName": "Tile 5: Energy and duration by temperature bucket",
      "queryLines": [
        "SELECT\n",
        "  temperature_bucket,\n",
        "  COUNT(*) AS sessions_count,\n",
        "  AVG(energy_kwh) AS avg_energy_kwh,\n",
        "  AVG(duration_minutes) AS avg_duration_minutes\n",
        "FROM\n",
        "  ev_charging_demo.silver.charging_sessions_enriched\n",
        "WHERE\n",
        "  is_valid_start_ts = true\n",
        "  AND is_valid_energy = true\n",
        "  AND is_valid_duration = true\n",
        "  AND is_duplicate = false\n",
        "  AND temperature_bucket IS NOT NULL\n",
        "GROUP BY\n",
        "  temperature_bucket\n",
        "ORDER BY\n",
        "  sessions_count DESC;"
      ]
    },
    {
      "name": "479c3781",
      "displayName": "Tile 6: Data quality summary",
      "queryLines": [
        "SELECT *\r\n",
        "FROM ev_charging_demo.gold.data_quality_summary;"
      ]
    }
  ],
